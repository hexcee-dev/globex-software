# Optional for now: app uses in-memory dummy data. Set this when you connect MongoDB later.
# MongoDB Atlas connection string from: Cluster → Connect → Connect your application
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# Optional: App URL for redirects (e.g. after logout). Defaults to http://localhost:3000 in development.
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# SEO: Used for sitemap, robots.txt, canonical URL, and Open Graph. Defaults to https://globexcargo.in
# NEXT_PUBLIC_SITE_URL=https://globexcargo.in
